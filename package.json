{
  "name": "geracao-em-massa-reels",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "start:worker": "node dist/src/worker/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/config tests/workflow tests/security tests/bot tests/renderer tests/db tests/server tests/queue tests/worker tests/packager tests/storage tests/delivery tests/ci",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.614.0",
    "@aws-sdk/s3-request-presigner": "^3.614.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@grammyjs/runner": "^2.0.3",
    "@libsql/client": "^0.17.4",
    "archiver": "^7.0.1",
    "bullmq": "^5.79.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.10.0",
    "file-type": "^21.3.4",
    "grammy": "^1.45.1",
    "ioredis": "^5.4.1",
    "nanoid": "^5.1.16",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@vitest/coverage-v8": "^4.1.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
